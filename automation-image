🔗 5. docker-compose.yml (FINAL)
version: '3.8'

services:
  jenkins:
    build:
      context: .
      dockerfile: Dockerfile.jenkins
    container_name: jenkins
    ports:
      - "8080:8080"
      - "50000:50000"
    volumes:
      - jenkins_home:/var/jenkins_home
      - /var/run/docker.sock:/var/run/docker.sock
    restart: always

  my-env:
    build:
      context: .
      dockerfile: Dockerfile.python
    container_name: my-env
    tty: true

volumes:
  jenkins_home:
⚙️ 6. Steps to run on ANY new server
Step 1: Install Docker
sudo apt update
sudo apt install -y docker.io docker-compose
sudo systemctl enable docker
sudo systemctl start docker
Step 2: Fix permission
sudo usermod -aG docker $USER
newgrp docker
Step 3: Copy your setup

👉 Copy devops-setup folder to new server

Step 4: Run everything
cd devops-setup

docker-compose down
docker-compose build --no-cache
docker-compose up -d
Step 5: Fix port issue (if needed)

If 8080 busy:

- "9090:8080"
Step 6: Access Jenkins
http://<server-ip>:8080
Step 7: Get password
docker exec -it jenkins cat /var/jenkins_home/secrets/initialAdminPassword
🔥 7. How Jenkins will use your Python env

Inside Jenkins pipeline:

pipeline {
    agent any

    stages {
        stage('Run Automation') {
            steps {
                sh 'docker exec my-env ansible --version'
                sh 'docker exec my-env python3 --version'
            }
        }
    }
}
